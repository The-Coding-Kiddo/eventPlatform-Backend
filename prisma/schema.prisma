generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─────────────────────────────────────────────────────────────────
// USER MODEL
// ─────────────────────────────────────────────────────────────────
model User {
  id               String    @id @default(uuid())
  name             String   
  email            String   @unique
  password         String   // Hashed securely (not sent to frontend)
  role             Role     @default(citizen)
  institution      String?
  bio              String?
  profilePicture   String?
  
  // Relationships (Linking Users to Events)
  savedEvents      Event[]  @relation("SavedEvents")
  registeredEvents Event[]  @relation("RegisteredEvents")
  
  // Follow system — citizens follow institutions
  followers        Follow[] @relation("Followed")
  following        Follow[] @relation("Follower")
  
  // PostgreSQL supports saving basic arrays directly
  subscriptions    String[]
  suspended        Boolean  @default(false)
  
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

enum Role {
  citizen
  institution
  super_admin
}

// ── Follow: citizens follow institutions ──
model Follow {
  id         String   @id @default(uuid())
  followerId String
  followedId String
  createdAt  DateTime @default(now())

  follower   User     @relation("Follower", fields: [followerId], references: [id])
  followed   User     @relation("Followed", fields: [followedId], references: [id])

  @@unique([followerId, followedId])
}

// ─────────────────────────────────────────────────────────────────
// EVENT MODEL
// ─────────────────────────────────────────────────────────────────
model Event {
  id              String      @id @default(uuid())
  title           String
  category        String
  date            String
  time            String
  location        String
  venue           String
  institution     String      // Name of the institution hosting the event
  description     String
  price           Float       @default(0)
  capacity        Int
  attendees       Int         @default(0)
  tags            String[]
  image           String?
  status          EventStatus @default(draft)
  checkedInUsers  String[]    @default([])
  waitlist        String[]    @default([])

  // Relationships
  registeredUsers User[]      @relation("RegisteredEvents")
  savedBy         User[]      @relation("SavedEvents")

  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
}

enum EventStatus {
  draft
  pending
  approved
  rejected
}

// ─────────────────────────────────────────────────────────────────
// NOTIFICATION MODEL
// ─────────────────────────────────────────────────────────────────
model Notification {
  id             String   @id @default(uuid())
  type           String
  title          String
  message        String
  read           Boolean  @default(false)
  userId         String?
  forRole        String?
  forCategory    String?
  forInstitution String?
  eventId        String?
  createdAt      DateTime @default(now())
}

// ─────────────────────────────────────────────────────────────────
// AUDIT LOG MODEL
// ─────────────────────────────────────────────────────────────────
model AuditLog {
  id        String   @id @default(uuid())
  userId    String
  userEmail String
  userRole  String
  action    String
  targetId  String?
  details   String?
  createdAt DateTime @default(now())
}
